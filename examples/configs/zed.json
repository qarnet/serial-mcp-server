{
  "$comment": "Merge into ~/.config/zed/settings.json under the 'context_servers' key.",
  "context_servers": {
    "serial-mcp-server": {
      "command": {
        "path": "/usr/local/bin/serial-mcp-server",
        "args": [],
        "env": {
          "RUST_LOG": "warn",
          "SERIAL_MCP_ALLOWLIST": "/dev/ttyACM*,/dev/ttyUSB*"
        }
      },
      "settings": {}
    }
  }
}
