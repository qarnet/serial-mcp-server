{
  "$comment": "Save as .vscode/mcp.json in your workspace root (VS Code Copilot MCP support).",
  "servers": {
    "serial": {
      "type": "stdio",
      "command": "/usr/local/bin/serial-mcp-server",
      "env": {
        "RUST_LOG": "warn",
        "SERIAL_MCP_ALLOWLIST": "/dev/ttyACM*,/dev/ttyUSB*"
      }
    }
  }
}
