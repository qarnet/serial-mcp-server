{
  "$comment": "Add to .cursor/mcp.json in your project root, or ~/.cursor/mcp.json globally.",
  "mcpServers": {
    "serial": {
      "command": "/usr/local/bin/serial-mcp-server",
      "env": {
        "RUST_LOG": "warn",
        "SERIAL_MCP_ALLOWLIST": "/dev/ttyACM*,/dev/ttyUSB*"
      }
    }
  }
}
